<Window x:Class="MonitorApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WindowHome"
        Height="900"
        Width="1440"
        MinHeight="620"
        MinWidth="760"
        Background="#FFEAF6"
        Foreground="#243044"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFE3F0"/>
        <SolidColorBrush x:Key="PanelAltBrush" Color="#F4E8FF"/>
        <SolidColorBrush x:Key="PanelMintBrush" Color="#DDF8F2"/>
        <SolidColorBrush x:Key="PanelBlueBrush" Color="#E0F1FF"/>
        <SolidColorBrush x:Key="PanelPeachBrush" Color="#FFECCF"/>
        <SolidColorBrush x:Key="InputBrush" Color="#FFF4FD"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#D9BFEF"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#76E2D1"/>
        <SolidColorBrush x:Key="AccentBlueBrush" Color="#70ACFF"/>
        <SolidColorBrush x:Key="AccentVioletBrush" Color="#B99AFF"/>
        <SolidColorBrush x:Key="AccentAmberBrush" Color="#FFC86B"/>
        <SolidColorBrush x:Key="AccentPinkBrush" Color="#FF9DCC"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#657189"/>
        <LinearGradientBrush x:Key="PrimaryGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF9DCC" Offset="0"/>
            <GradientStop Color="#B99AFF" Offset="0.52"/>
            <GradientStop Color="#76E2D1" Offset="1"/>
        </LinearGradientBrush>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#243044"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="Foreground" Value="#243044"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="MinHeight" Value="34"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="Foreground" Value="#243044"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{StaticResource InputBrush}"
                                                BorderBrush="{StaticResource BorderBrushSoft}"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="34"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Margin="10,0,4,0"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="v"
                                                           Foreground="#8F69D9"
                                                           FontWeight="Bold"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Background="#F8EFFF"
                                        BorderBrush="{StaticResource AccentVioletBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer Margin="4" MaxHeight="260">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#243044"/>
            <Setter Property="Background" Value="#F8EFFF"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#DDF8F2"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#FFECCF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#243044"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#F2DFFF"/>
            <Setter Property="Foreground" Value="#243044"/>
            <Setter Property="BorderBrush" Value="#DFC8F5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource PrimaryGradientBrush}"/>
            <Setter Property="Foreground" Value="#243044"/>
            <Setter Property="BorderBrush" Value="#FF79BA"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#243044"/>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,18">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <CheckBox x:Name="AutoStartCheck"
                          Content="Autostart"
                          Margin="0,0,14,0"
                          ToolTip="Start WindowHome automatically when you sign in to Windows."
                          Checked="AutoStartCheck_Changed"
                          Unchecked="AutoStartCheck_Changed"/>
                <CheckBox x:Name="ElevatedStartupCheck"
                          Content="Admin startup"
                          Margin="0,0,14,0"
                          ToolTip="Create or remove a Windows Task Scheduler entry that starts WindowHome with administrator privileges when you sign in."
                          Checked="ElevatedStartupCheck_Changed"
                          Unchecked="ElevatedStartupCheck_Changed"/>
                <CheckBox x:Name="MinimizeToTrayCheck"
                          Content="Minimize to tray on launch"
                          Margin="0,0,14,0"
                          ToolTip="When checked, WindowHome starts hidden in the notification area when launched by you or Windows."
                          Checked="MinimizeToTrayCheck_Changed"
                          Unchecked="MinimizeToTrayCheck_Changed"/>
                <Button Content="Sound Control"
                        Click="SoundControlButton_Click"
                        Margin="0,0,14,0"
                        ToolTip="Open the separate sound-control window for shared per-app volume hotkeys."/>
                <Button Content="Hide" Click="HideButton_Click" ToolTip="Hide WindowHome to the notification area."/>
            </StackPanel>
            <StackPanel>
                <TextBlock Text="WindowHome" FontSize="30" FontWeight="SemiBold"/>
                <TextBlock x:Name="MonitorCountText"
                           Foreground="{StaticResource TextMutedBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1"
                Background="{StaticResource PanelPeachBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12"
                Margin="0,0,0,14">
            <TextBlock Text="Note: Some applications require administrator permission before Windows lets another app launch or move them. If a saved app needs administrator permission, start WindowHome as administrator too. Admin startup also requires starting WindowHome as administrator before enabling it."
                       Foreground="{StaticResource TextMutedBrush}"/>
        </Border>

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto">
        <Grid MinWidth="1360">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*"/>
                <ColumnDefinition Width="1.45*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource PanelBlueBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="Saved Apps" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </DockPanel>

                    <ListBox x:Name="RulesList"
                             Grid.Row="1"
                             SelectionChanged="RulesList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="8" MinHeight="72">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding DisplayName, Mode=OneWay}" FontWeight="SemiBold" FontSize="15"/>
                                        <TextBlock Text="{Binding MatchLabel, Mode=OneWay}"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="12"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Foreground="{StaticResource AccentBlueBrush}" FontSize="12">
                                            <Run Text="{Binding TargetMonitorLabel, Mode=OneWay}"/>
                                            <Run Text="  |  "/>
                                            <Run Text="{Binding PlacementLabel, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding AutomationLabel, Mode=OneWay}"
                                                   Foreground="{StaticResource AccentPinkBrush}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="Start App" Click="StartAppButton_Click" Margin="0,0,8,0" ToolTip="Start the selected saved app now."/>
                        <Button Content="Move Now" Click="MoveNowButton_Click" Margin="0,0,8,0" ToolTip="Apply the selected rule to matching open windows now."/>
                        <Button Content="Delete" Click="DeleteRuleButton_Click" ToolTip="Delete the selected saved app rule."/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{StaticResource PanelMintBrush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Active Monitors" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <ItemsControl x:Name="MonitorList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource PanelAltBrush}"
                                                BorderBrush="{StaticResource BorderBrushSoft}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="10"
                                                Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                                <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="12">
                                                    <Run Text="Bounds "/>
                                                    <Run Text="{Binding Bounds.Left}"/>
                                                    <Run Text=","/>
                                                    <Run Text="{Binding Bounds.Top}"/>
                                                    <Run Text=" "/>
                                                    <Run Text="{Binding Bounds.Width}"/>
                                                    <Run Text="x"/>
                                                    <Run Text="{Binding Bounds.Height}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Background="{StaticResource PanelPeachBrush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,10">
                                <Button DockPanel.Dock="Right" Content="Refresh" Click="RefreshButton_Click" ToolTip="Refresh monitors and current windows."/>
                                <TextBlock Text="Current Windows" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </DockPanel>
                            <ComboBox x:Name="ProcessCombo"
                                      DisplayMemberPath="DisplayLabel"
                                      ToolTip="Choose an open window to capture or use for a rule."
                                      SelectionChanged="ProcessCombo_SelectionChanged"/>
                            <TextBlock Text="Filter by process or title"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="12"
                                       Margin="0,8,0,4"/>
                            <TextBox x:Name="WindowFilterBox"
                                     ToolTip="Type part of an app name, window title, or path to filter Current Windows."
                                     TextChanged="WindowFilterBox_TextChanged"/>
                            <TextBlock x:Name="WindowPreviewText"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Margin="0,8,0,0"
                                       MinHeight="38"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Use Process" Click="UseProcessButton_Click" ToolTip="Copy the selected current window's app name, process, and executable path into the rule editor."/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="1"
                        Background="{StaticResource PanelAltBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Rule Editor" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,12">
                            <TextBlock Text="App Name" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,5"/>
                            <TextBox x:Name="NameBox" ToolTip="Friendly name shown in Saved Apps."/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,12">
                            <TextBlock Text="Target Monitor" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,5"/>
                            <ComboBox x:Name="MonitorCombo" DisplayMemberPath="DisplayName" ToolTip="Monitor where matching windows should be placed."/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,12">
                            <TextBlock Text="Executable Path" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,5"/>
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="Browse" Click="BrowseExeButton_Click" Margin="10,0,0,0" ToolTip="Choose the app executable file."/>
                                <TextBox x:Name="ExePathBox" ToolTip="Executable path used to match and start this app."/>
                            </DockPanel>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,10,12">
                            <TextBlock Text="Process Name" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,5"/>
                            <TextBox x:Name="ProcessNameBox" ToolTip="Process name used to match windows when the executable path is unavailable."/>
                        </StackPanel>
                        <StackPanel Grid.Row="3" Grid.Column="1" Margin="10,0,0,12">
                            <TextBlock Text="Placement" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,5"/>
                            <ComboBox x:Name="ModeCombo" SelectionChanged="ModeCombo_SelectionChanged" ToolTip="Choose how the window should appear after WindowHome positions it.">
                                <ComboBoxItem Content="Exact position"/>
                                <ComboBoxItem Content="Maximized"/>
                                <ComboBoxItem Content="Minimized to taskbar"/>
                            </ComboBox>
                        </StackPanel>

                        <Grid Grid.Row="4" Grid.ColumnSpan="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <CheckBox x:Name="RuleAutoStartCheck"
                                      Grid.Row="0"
                                      Content="Autostart"
                                      ToolTip="Start this saved app once when WindowHome starts. Saving the rule will not start it immediately."
                                      Margin="0,0,0,12"/>
                            <StackPanel Grid.Row="1">
                                <Grid x:Name="ExactPositionGrid">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="Left" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,5"/>
                                        <TextBox x:Name="LeftBox" ToolTip="Saved left offset from the target monitor."/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="8,0,8,0">
                                        <TextBlock Text="Top" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,5"/>
                                        <TextBox x:Name="TopBox" ToolTip="Saved top offset from the target monitor."/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Margin="8,0,8,0">
                                        <TextBlock Text="Width" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,5"/>
                                        <TextBox x:Name="WidthBox" ToolTip="Saved window width."/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" Margin="8,0,0,0">
                                        <TextBlock Text="Height" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,5"/>
                                        <TextBox x:Name="HeightBox" ToolTip="Saved window height."/>
                                    </StackPanel>
                                </Grid>
                                <StackPanel Margin="0,12,0,0">
                                    <TextBlock Text="Minimize to tray" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="TrayActionCombo" ToolTip="Choose whether WindowHome should use the app's minimize or close button behavior to send it to the notification area.">
                                        <ComboBoxItem Content="Do not minimize to tray"/>
                                        <ComboBoxItem Content="Minimize button to minimize to tray"/>
                                        <ComboBoxItem Content="Close button to minimize to tray"/>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="5" Grid.ColumnSpan="2" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="StatusText"
                                       Grid.Column="0"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,0,12,0"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="Save Current Position"
                                        Style="{StaticResource PrimaryButton}"
                                        Click="SaveCurrentPositionButton_Click"
                                        ToolTip="Save the currently selected open window's monitor, size, position, and selected options."
                                        MinWidth="142"
                                        Margin="0,0,8,0"/>
                                <Button Content="Save Rule"
                                        Style="{StaticResource PrimaryButton}"
                                        MinWidth="92"
                                        ToolTip="Save the values currently shown in the rule editor."
                                        Click="SaveRuleButton_Click"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
        </ScrollViewer>

        <TextBlock Grid.Row="3"
                   Text="Runs while open or hidden. Saved rules apply once per matching top-level window when detected."
                   Foreground="{StaticResource TextMutedBrush}"
                   Margin="0,14,0,0"/>
    </Grid>
</Window>
