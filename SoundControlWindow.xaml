<Window x:Class="MonitorApp.SoundControlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WindowHome Sound Control"
        Height="760"
        Width="1260"
        MinHeight="620"
        MinWidth="920"
        Background="#FFEAF6"
        Foreground="#243044"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFE3F0"/>
        <SolidColorBrush x:Key="PanelAltBrush" Color="#F4E8FF"/>
        <SolidColorBrush x:Key="PanelMintBrush" Color="#DDF8F2"/>
        <SolidColorBrush x:Key="PanelBlueBrush" Color="#E0F1FF"/>
        <SolidColorBrush x:Key="PanelPeachBrush" Color="#FFECCF"/>
        <SolidColorBrush x:Key="InputBrush" Color="#FFF4FD"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#D9BFEF"/>
        <SolidColorBrush x:Key="AccentBlueBrush" Color="#70ACFF"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#657189"/>
        <LinearGradientBrush x:Key="PrimaryGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF9DCC" Offset="0"/>
            <GradientStop Color="#B99AFF" Offset="0.52"/>
            <GradientStop Color="#76E2D1" Offset="1"/>
        </LinearGradientBrush>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#243044"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="Foreground" Value="#243044"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="MinHeight" Value="34"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="Foreground" Value="#243044"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="MinHeight" Value="34"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#F2DFFF"/>
            <Setter Property="Foreground" Value="#243044"/>
            <Setter Property="BorderBrush" Value="#DFC8F5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource PrimaryGradientBrush}"/>
            <Setter Property="Foreground" Value="#243044"/>
            <Setter Property="BorderBrush" Value="#FF79BA"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#243044"/>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Sound Control" FontSize="28" FontWeight="SemiBold"/>
            <TextBlock Text="Global volume hotkeys affect only apps saved in this screen. If none are running, hotkeys do nothing."
                       Foreground="{StaticResource TextMutedBrush}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="{StaticResource PanelPeachBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12"
                Margin="0,0,0,14">
            <TextBlock Text="Pick a current window to fill the editor quickly, or browse to an executable. Volume Up, Volume Down, and Mute are shared by every saved sound app."
                       Foreground="{StaticResource TextMutedBrush}"/>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.02*"/>
                <ColumnDefinition Width="1.38*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource PanelBlueBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Saved Sound Apps" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <ListBox x:Name="SoundRulesList" Grid.Row="1" SelectionChanged="SoundRulesList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="8" MinHeight="66">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="15"/>
                                        <TextBlock Text="{Binding MatchLabel}" Foreground="{StaticResource TextMutedBrush}" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="Uses shared volume hotkeys" Foreground="{StaticResource AccentBlueBrush}" FontSize="12"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="New" Click="NewRuleButton_Click" Margin="0,0,8,0" ToolTip="Clear the editor to create a new saved sound app."/>
                        <Button Content="Delete" Click="DeleteRuleButton_Click" ToolTip="Delete the selected saved sound app."/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource PanelMintBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,10">
                            <Button DockPanel.Dock="Right" Content="Refresh" Click="RefreshButton_Click" ToolTip="Refresh the current windows list for sound-app selection."/>
                            <TextBlock Text="Current Windows" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </DockPanel>
                        <ComboBox x:Name="ProcessCombo" DisplayMemberPath="DisplayLabel" ToolTip="Choose a current window to fill the sound-app editor." SelectionChanged="ProcessCombo_SelectionChanged"/>
                        <TextBlock Text="Filter by process or title" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,8,0,4"/>
                        <TextBox x:Name="WindowFilterBox" ToolTip="Type part of an app name, window title, or path to filter Current Windows." TextChanged="WindowFilterBox_TextChanged"/>
                        <TextBlock x:Name="WindowPreviewText" Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,0" MinHeight="38"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Use Process" Click="UseProcessButton_Click" ToolTip="Copy the selected current window's app name, process, and executable path into the sound-app editor."/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Background="{StaticResource PanelAltBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Sound App Editor" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,12">
                                <TextBlock Text="App Name" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,5"/>
                                <TextBox x:Name="NameBox" ToolTip="Friendly name shown in Saved Sound Apps."/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,12">
                                <TextBlock Text="Process Name" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,5"/>
                                <TextBox x:Name="ProcessNameBox" ToolTip="Process name used to match the audio session when the executable path is unavailable."/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,0,0,12">
                                <TextBlock Text="Executable Path" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,5"/>
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Content="Browse" Click="BrowseExeButton_Click" Margin="10,0,0,0" ToolTip="Choose the executable file for this saved sound app."/>
                                    <TextBox x:Name="ExePathBox" ToolTip="Executable path used to match the app's audio session."/>
                                </DockPanel>
                            </StackPanel>

                            <Border Grid.Row="3" Grid.ColumnSpan="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Global Volume Hotkeys" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Volume Up" VerticalAlignment="Center" Margin="0,0,12,8"/>
                                    <Button Grid.Row="1" Grid.Column="1" x:Name="VolumeUpHotkeyButton" Click="VolumeUpHotkeyButton_Click" ToolTip="Set the shared hotkey that raises volume for every running saved sound app." Margin="0,0,0,8"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Volume Down" VerticalAlignment="Center" Margin="0,0,12,8"/>
                                    <Button Grid.Row="2" Grid.Column="1" x:Name="VolumeDownHotkeyButton" Click="VolumeDownHotkeyButton_Click" ToolTip="Set the shared hotkey that lowers volume for every running saved sound app." Margin="0,0,0,8"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Mute Toggle" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <Button Grid.Row="3" Grid.Column="1" x:Name="MuteHotkeyButton" Click="MuteHotkeyButton_Click" ToolTip="Set the shared hotkey that toggles mute for every running saved sound app."/>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="4" Grid.ColumnSpan="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="StatusText" Grid.Column="0" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Margin="0,0,12,0"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Content="Save Sound App" Style="{StaticResource PrimaryButton}" MinWidth="128" Click="SaveRuleButton_Click" ToolTip="Save the values currently shown in the sound-app editor."/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
